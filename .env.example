# FireDeepResearch local configuration

# API and storage
FDR_API_PORT=8787
FDR_DATA_DIR=./knowledge

# Provider mode:
# - auto: use mock providers when no Exa/Tavily key is present
# - true: force mock providers for demos/tests
# - false: prefer configured commercial providers, falling back to mock if none are configured
FDR_USE_MOCK_PROVIDERS=auto

# Frontend API target
VITE_API_URL=http://localhost:8787

# Parallel research execution limits. Values must be integers from 1 to 64.
FDR_MAX_SEARCH_AGENTS=6
FDR_MAX_READER_AGENTS=10
FDR_MAX_CRITIQUE_AGENTS=4

# Pi role runner. Leave empty to use deterministic local fallback output.
# FDR_LLM_MODEL accepts either "provider/model" or just "model" with FDR_LLM_PROVIDER.
FDR_LLM_PROVIDER=
FDR_LLM_MODEL=

# Model-provider keys used by @earendil-works/pi-ai when FDR_LLM_MODEL is configured.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_BASE_URL=
MISTRAL_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Commercial research providers
EXA_API_KEY=
TAVILY_API_KEY=
FIRECRAWL_API_KEY=
