# FireDeepResearch local configuration

# API and storage
FDR_API_PORT=8787
FDR_DATA_DIR=./knowledge

# Provider mode:
# - auto: use mock providers when no Exa/Tavily key is present
# - true: force mock providers for demos/tests
# - false: prefer configured commercial providers, falling back to mock if none are configured
FDR_USE_MOCK_PROVIDERS=auto

# Frontend API target
VITE_API_URL=http://localhost:8787

# Browser CORS origins. Empty allows localhost/127.0.0.1 dev origins on any port.
# For a deployed API, set a comma-separated allowlist such as:
# FDR_CORS_ORIGIN=https://research.example.com
FDR_CORS_ORIGIN=

# Parallel research execution limits. Values must be integers from 1 to 64.
FDR_MAX_SEARCH_AGENTS=6
FDR_MAX_READER_AGENTS=10
FDR_MAX_CRITIQUE_AGENTS=4

# Commercial provider resilience
FDR_PROVIDER_TIMEOUT_MS=20000
FDR_PROVIDER_RETRY_ATTEMPTS=2
FDR_PROVIDER_RETRY_DELAY_MS=400

# Live smoke checks. Missing live credentials are skipped by default.
# Set this to true in CI/final acceptance when provider/model keys must be present.
FDR_REQUIRE_LIVE_SMOKE=false
FDR_LOCAL_SMOKE_OUT_DIR=/tmp/fdr-local-smoke-ui
FDR_LIVE_PROVIDER_TIMEOUT_MS=15000
FDR_LIVE_PROVIDER_RETRY_ATTEMPTS=0
FDR_LIVE_PROVIDER_RETRY_DELAY_MS=250
FDR_LIVE_PROVIDER_QUERY=FireDeepResearch auditable deep research source credibility
FDR_LIVE_FIRECRAWL_URL=https://example.com/

# Pi role runner. Leave empty to use deterministic local fallback output.
# FDR_LLM_PROVIDER takes priority when set, so FDR_LLM_MODEL may contain slashes.
# Without FDR_LLM_PROVIDER, FDR_LLM_MODEL accepts "provider/model" shorthand.
# For provider-routed model ids containing slashes, include the provider first or set FDR_LLM_PROVIDER:
#   FDR_LLM_MODEL=openrouter/anthropic/claude-sonnet-4
#   FDR_LLM_PROVIDER=openrouter
#   FDR_LLM_MODEL=anthropic/claude-sonnet-4
FDR_LLM_PROVIDER=
FDR_LLM_MODEL=

# Model-provider keys used by @earendil-works/pi-ai when FDR_LLM_MODEL is configured.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_BASE_URL=
MISTRAL_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Commercial research providers
EXA_API_KEY=
TAVILY_API_KEY=
FIRECRAWL_API_KEY=
